  (text "ESP32-S3-WROOM-1-N8:\nhttps://www.lcsc.com/product-detail/WiFi-Modules_Espressif-Systems-ESP32-S3-WROOM-1-N8_C2913198.html"
    (at 0 -5.715 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 016915a6-fa56-449a-a5ab-f31e9633fed2)
  )
  (text "This micro switch might be a good idea!\n\nhttps://www.lcsc.com/product-detail/Tactile-Switches_BZCN-TSB013A4318A02_C2888459.html"
    (at 246.38 7.62 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 15832116-5b00-4c74-9768-84facea03761)
  )
  (text "Up to a max of 3.3V!" (at 212.09 28.575 0)
    (effects (font (size 1.27 1.27) (color 255 0 44 1)) (justify left bottom))
    (uuid 28d20302-fc5a-4675-b953-20107e5103ef)
  )
  (text "Vgs (NO USB) = -8.4V (BAT ON)\nVgs (USB) = 5 - 8.4 = -3.4V (BAT Part ON)\n\nI need a PNP with a Vgsth > -3.4V"
    (at 277.495 182.245 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 2bbf557c-937b-4b41-af29-1d9fe25911cb)
  )
  (text "Design example of the LIS3DH:\n\nhttps://cdn.sparkfun.com/datasheets/Sensors/Accelerometers/\nSparkFun_LIS3DH-Breakout.pdf?_gl=1*87mccp*_ga*MjA1MDY4MTg4NC4xNjg4ODM3Nzc3*_ga_T369JS7J9N*MTY5MTMzNjkzNi43LjEuMTY5MTMzODU4Mi42MC4wLjA."
    (at 16.51 195.58 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 448cb741-1c0b-4a8f-a7f3-ea7b382a9a3d)
  )
  (text "JST XH:\n\nhttps://www.lcsc.com/product-detail/Wire-To-Board-Wire-To-Wire-Connector_BOOMELE-Boom-Precision-Elec-XH-2AW_C33132.html"
    (at 170.18 -1.905 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 9eca7038-79fe-4eb4-b29a-92062344e71b)
  )
  (text "JTAG" (at 107.315 69.215 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid b2d8435a-7307-4fd2-a131-d56f59afaf6f)
  )
  (text "Dual Diode approach will suffice for now.\nLater I'll look into a better circuit. \nThe Vdrop is about 0.4V"
    (at 277.495 144.78 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid bf88cdab-8e0b-4976-81ba-21ee350dc127)
  )
  (text "OTG + CDC won't work \nwithout an add. part." (at 142.875 50.165 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid c1afcbd4-0400-4d38-a55e-a0e9b10b4125)
  )
  (text "Nope." (at 123.825 112.395 0)
    (effects (font (size 1.27 1.27) (color 255 0 0 1)) (justify left bottom))
    (uuid d1d8ddf0-1111-415f-af33-83830e3346a0)
  )
  (text "power switch before the buck converter, \nclose to the battery."
    (at 328.295 140.335 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d8a3866d-68c8-489d-9fd5-75218614326e)
  )
  (text "FL, i.e. front left.\nBR, i.e. back right." (at 278.13 65.405 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid f35ede35-161a-4734-a765-4d984999be73)
  )
  (text "These pins are used by the PSRAM, if there is any."
    (at 24.765 122.555 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid f4570829-2fff-40f0-aebb-5f81e432ca98)
  )
  (text "Recommended is 3.9uH!" (at 292.735 95.25 0)
    (effects (font (size 1.27 1.27) (color 194 0 0 1)) (justify left bottom))
    (uuid f83e2371-3199-407d-9a27-22edb9e7f970)
  )

